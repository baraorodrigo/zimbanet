# === Supabase (obrigatório) ===
# Project Settings → API: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role — server-side apenas (createAdminClient). Nunca exponha no client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Site (URL pública usada em metadata, sitemap, OG, feed RSS) ===
# Em dev pode deixar vazio que cai pra https://zimbanet.com no fallback.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Web Push (breaking news) ===
# Gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@zimbanet.com
# Mesma chave pública do VAPID_PUBLIC_KEY, exposta ao client pra subscribe()
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# === Integrações internas ===
# Token usado pelo radar regional pra disparar push automático (/api/push/breaking)
INTERNAL_PUSH_TOKEN=
# Base URL do worker de scraping (radar-regional / zimbanet-radar)
RADAR_BASE_URL=http://127.0.0.1:8100
# Token usado pelo /api/social/render (Puppeteer interno do social kit)
RENDER_API_TOKEN=

# === Provedores de IA (opcional — configuração principal é por slot em /admin/configuracoes) ===
# Estas envs servem como fallback quando o slot não tem chave própria no DB.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
FAL_KEY=

# === Analytics (opcional) ===
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=zimbanet.com
# Sobrescreve o script src do Plausible (self-hosted, proxy etc.). Default: https://plausible.io/js/script.js
NEXT_PUBLIC_PLAUSIBLE_SRC=

# === Auth dev shortcut (apenas dev/staging — nunca em prod) ===
# Senha do botão "Entrar como dev" no /login. Sem isto, o botão fica desabilitado.
ZIMBANET_DEV_PASSWORD=
