# Radar production env — VPS teste.zimbanet.com
# Este arquivo NUNCA vai pro git. Criar manualmente no VPS em ./radar/.env.production

# === Anthropic =============================================================
# SDK oficial — precisa de chave Anthropic direta (sk-ant-...), não OpenRouter
ANTHROPIC_API_KEY=sk-ant-api03-...

# === Supabase ==============================================================
SUPABASE_URL=https://gavgzpbqrryepgqxzvdk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# === Modelos ===============================================================
MODEL_CURADOR=claude-haiku-4-5-20251001
MODEL_INVESTIGADOR=claude-sonnet-4-6
MODEL_REDATOR=claude-sonnet-4-6
MODEL_VISUAL=claude-haiku-4-5-20251001
MODEL_ANALISTA=claude-haiku-4-5-20251001

# === Comportamento =========================================================
ENV=prod
LOG_LEVEL=INFO
SCHEDULE_ENABLED=false
PORT=8100

# === Auto-publish (default desligado — operador aprova manual) =============
AUTOPUBLISH_ENABLED=false
AUTOPUBLISH_MIN_CONFIDENCE=0.78
AUTOPUBLISH_MAX_RISK=0.35

# === Integração com portal Next.js (mesma docker network) ==================
PORTAL_BASE_URL=http://portal:3000
RENDER_API_TOKEN=
RENDER_ENABLED=true

# === Push (manda via /api/push/breaking do portal) =========================
INTERNAL_PUSH_TOKEN=
PUSH_ENABLED=true
