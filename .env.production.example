# PROD — referência das envs necessárias em produção.
# Valores reais ficam no painel de deploy (Vercel/Hostinger), NUNCA commitar.

# === Supabase (obrigatório) ===
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# PROD: setar como secret no painel — nunca expor no client nem versionar.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === Site ===
# Domínio canônico em prod.
NEXT_PUBLIC_SITE_URL=https://zimbanet.com

# === Web Push (breaking news) ===
# PROD: gerar UMA vez com `npx web-push generate-vapid-keys` e guardar no cofre.
# Trocar quebra todas as subscriptions ativas — só rotacionar em incidente.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@zimbanet.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# === Integrações internas ===
# PROD: tokens longos (>=32 chars aleatórios), rotacionar a cada incidente.
INTERNAL_PUSH_TOKEN=
RADAR_BASE_URL=https://radar.zimbanet.com
RENDER_API_TOKEN=

# === Provedores de IA (opcional — preferência é config por slot em /admin/configuracoes) ===
# PROD: deixe vazio aqui se a chave já estiver salva no DB pelo admin.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
FAL_KEY=

# === Analytics ===
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=zimbanet.com
NEXT_PUBLIC_PLAUSIBLE_SRC=
